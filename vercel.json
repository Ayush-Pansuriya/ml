{
    "version": 2,
    "builds": [
        {
            "src": "my-app/package.json",
            "use": "@vercel/next"
        },
        {
            "src": "my-app/api/*.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "my-app/api/$1.py"
        },
        {
            "src": "/(.*)",
            "dest": "my-app/$1"
        }
    ]
}